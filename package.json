{
  "name": "@airstrings/react-native",
  "version": "0.1.1",
  "description": "AirStrings React Native SDK — fetch, verify, cache, and serve Ed25519-signed localized string bundles",
  "keywords": [
    "airstrings",
    "i18n",
    "l10n",
    "localization",
    "internationalization",
    "icu",
    "messageformat",
    "ed25519",
    "cdn",
    "sdk",
    "react-native"
  ],
  "author": "Symbionix <info@symbionix.io>",
  "license": "MIT",
  "homepage": "https://github.com/symbionix-sl/airstrings-sdk-react-native#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/symbionix-sl/airstrings-sdk-react-native.git"
  },
  "bugs": {
    "url": "https://github.com/symbionix-sl/airstrings-sdk-react-native/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "./src/intl-polyfill.ts",
    "./dist/index.cjs",
    "./dist/index.mjs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.8.0"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.19.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@formatjs/intl-pluralrules": "^6.3.10",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "intl-messageformat": "^11.1.3",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
